# BNI/BIONS Sentiment Analysis - Collector Config
# Copy this file to .env and fill in values. Never commit .env.

# MongoDB
MONGO_PORT=27017
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=bni_bions_sentiment

# YouTube
YOUTUBE_API_KEY=
YOUTUBE_BACKFILL_MAX_REQUESTS=10
YOUTUBE_BACKFILL_REQUEST_DELAY_SECONDS=2

# X/Twitter
X_BEARER_TOKEN=
X_SEARCH_QUERIES=BIONS lang:id -is:retweet,BNI Sekuritas lang:id -is:retweet
X_OFFICIAL_USERNAMES=BNI1946,bnisekuritas46

# TikTok Research API
TIKTOK_RESEARCH_ACCESS_TOKEN=
TIKTOK_VIDEO_IDS=

# TikTok public oembed
TIKTOK_TARGET_URLS=

# Instagram Graph API
INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_MEDIA_IDS=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_HASHTAG_QUERIES=

# Threads Graph API
THREADS_ACCESS_TOKEN=
THREADS_MEDIA_IDS=
THREADS_SEARCH_QUERIES=

# Stockbit public scrape
STOCKBIT_TARGET_URLS=

# App Store / Google Play
APP_STORE_APP_ID=6736508566
GOOGLE_PLAY_PACKAGE_ID=id.bions.bnis.android
